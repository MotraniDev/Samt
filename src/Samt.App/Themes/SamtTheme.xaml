<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
      Stitch + frontend-design — SAMT «Night Mosque»
      Deep navy field, quiet gold accent, forest undertone, ivory type.
      Arabic-first: Cairo (modern UI), Amiri (decorative display), Noto Naskh (adhkar).
      Signature: next-prayer countdown in gold on navy; alert uses islamic-tile texture.
      Digits: always Latin 0–9 via LatinDigits* styles.
    -->

    <!-- Palette (aligned with Stitch screen-2971f4d3 / prior tokens) -->
    <Color x:Key="SamtNavyColor">#0B1F33</Color>
    <Color x:Key="SamtNavyDeepColor">#071525</Color>
    <Color x:Key="SamtNavyMidColor">#14324F</Color>
    <Color x:Key="SamtSurfaceColor">#0D2135</Color>
    <Color x:Key="SamtSurfaceHighColor">#182B40</Color>
    <Color x:Key="SamtGoldColor">#C4A35A</Color>
    <Color x:Key="SamtGoldSoftColor">#E0C989</Color>
    <Color x:Key="SamtGoldBrightColor">#E5C276</Color>
    <Color x:Key="SamtIvoryColor">#F4EFE4</Color>
    <Color x:Key="SamtIvoryMutedColor">#E8E0D0</Color>
    <Color x:Key="SamtGreenColor">#1F4D3A</Color>
    <Color x:Key="SamtGreenSoftColor">#2A6B50</Color>
    <Color x:Key="SamtMintColor">#A1D1B8</Color>

    <SolidColorBrush x:Key="SamtNavyBrush" Color="{StaticResource SamtNavyColor}" />
    <SolidColorBrush x:Key="SamtNavyDeepBrush" Color="{StaticResource SamtNavyDeepColor}" />
    <SolidColorBrush x:Key="SamtNavyMidBrush" Color="{StaticResource SamtNavyMidColor}" />
    <SolidColorBrush x:Key="SamtSurfaceBrush" Color="{StaticResource SamtSurfaceColor}" />
    <SolidColorBrush x:Key="SamtSurfaceHighBrush" Color="{StaticResource SamtSurfaceHighColor}" />
    <SolidColorBrush x:Key="SamtGoldBrush" Color="{StaticResource SamtGoldColor}" />
    <SolidColorBrush x:Key="SamtGoldSoftBrush" Color="{StaticResource SamtGoldSoftColor}" />
    <SolidColorBrush x:Key="SamtGoldBrightBrush" Color="{StaticResource SamtGoldBrightColor}" />
    <SolidColorBrush x:Key="SamtIvoryBrush" Color="{StaticResource SamtIvoryColor}" />
    <SolidColorBrush x:Key="SamtIvoryMutedBrush" Color="{StaticResource SamtIvoryMutedColor}" />
    <SolidColorBrush x:Key="SamtGreenBrush" Color="{StaticResource SamtGreenColor}" />
    <SolidColorBrush x:Key="SamtMintBrush" Color="{StaticResource SamtMintColor}" />
    <SolidColorBrush x:Key="SamtAccentBrush" Color="{StaticResource SamtGoldColor}" />
    <SolidColorBrush x:Key="SamtCardBrush" Color="#14C4A35A" />
    <SolidColorBrush x:Key="SamtCardElevatedBrush" Color="#1AC4A35A" />
    <SolidColorBrush x:Key="SamtHeroScrimBrush" Color="#990B1F33" />
    <SolidColorBrush x:Key="SamtOrnamentBrush" Color="#33C4A35A" />
    <SolidColorBrush x:Key="SamtHairlineBrush" Color="#33E0C989" />

    <LinearGradientBrush x:Key="SamtHeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0B1F33" Offset="0" />
        <GradientStop Color="#14324F" Offset="0.55" />
        <GradientStop Color="#1F4D3A" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SamtShellGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#071525" Offset="0" />
        <GradientStop Color="#0B1F33" Offset="1" />
    </LinearGradientBrush>

    <!--
      Typography — single-family values only (multi-fallback lists misbehave in WinUI).
      Folder + family name lets FontWeight resolve Regular / Medium / SemiBold / Bold files.
    -->
    <!-- Modern geometric Arabic UI (Cairo OFL). -->
    <FontFamily x:Key="SamtUiFont">ms-appx:///Assets/Fonts/Cairo/#Cairo</FontFamily>
    <!-- Decorative naskh for prayer names / page titles. -->
    <FontFamily x:Key="SamtDisplayFont">ms-appx:///Assets/Fonts/Amiri/#Amiri</FontFamily>
    <!-- Body Arabic for adhkar lines. -->
    <FontFamily x:Key="SamtNaskhFont">ms-appx:///Assets/Fonts/NotoNaskhArabic/#Noto Naskh Arabic</FontFamily>
    <FontFamily x:Key="SamtNumericFont">Cascadia Mono</FontFamily>
    <!-- Fallback modern Arabic if Cairo folder fails to resolve. -->
    <FontFamily x:Key="SamtUiFontFallback">ms-appx:///Assets/Fonts/IBMPlexSansArabic/#IBM Plex Sans Arabic</FontFamily>

    <!-- App-wide control face (Arabic-capable). Numbers still use LatinDigits*. -->
    <FontFamily x:Key="ContentControlThemeFontFamily">ms-appx:///Assets/Fonts/Cairo/#Cairo</FontFamily>

    <Style x:Key="SamtPageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SamtDisplayFont}" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SamtGoldBrush}" />
        <Setter Property="CharacterSpacing" Value="20" />
    </Style>

    <Style x:Key="SamtSectionLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SamtUiFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="CharacterSpacing" Value="40" />
        <Setter Property="Opacity" Value="0.72" />
    </Style>

    <Style x:Key="SamtBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SamtUiFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="LineHeight" Value="24" />
    </Style>

    <Style x:Key="SamtDisplayText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SamtDisplayFont}" />
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource SamtIvoryBrush}" />
    </Style>

    <Style x:Key="SamtNaskhText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource SamtNaskhFont}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="LineHeight" Value="36" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!--
      Rule: always Latin digits 0-9.
      Language=en-US prevents WinUI digit substitution under Arabic UI.
    -->
    <Style x:Key="LatinDigitsTextBlock" TargetType="TextBlock">
        <Setter Property="Language" Value="en-US" />
        <Setter Property="FontFamily" Value="{StaticResource SamtNumericFont}" />
    </Style>

    <Style x:Key="LatinDigitsTextBox" TargetType="TextBox">
        <Setter Property="Language" Value="en-US" />
        <Setter Property="FontFamily" Value="{StaticResource SamtNumericFont}" />
    </Style>

    <Style x:Key="LatinDigitsCalendar" TargetType="CalendarDatePicker">
        <Setter Property="Language" Value="en-US" />
    </Style>

    <Style x:Key="SamtCountdownText" TargetType="TextBlock" BasedOn="{StaticResource LatinDigitsTextBlock}">
        <Setter Property="FontSize" Value="52" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="-20" />
        <Setter Property="Foreground" Value="{StaticResource SamtGoldSoftBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="SamtPrayerRowTime" TargetType="TextBlock" BasedOn="{StaticResource LatinDigitsTextBlock}">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource SamtGoldBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Card chrome (Stitch glass / elevated surface) -->
    <Style x:Key="SamtCardBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SamtHairlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="SamtPillBorder" TargetType="Border">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Background" Value="{StaticResource SamtCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource SamtGoldBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
</ResourceDictionary>
