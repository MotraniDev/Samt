<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Samt_App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Samt_App"
    Title="سَمت / SAMT">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar (replaces system caption) -->
        <Grid
            x:Name="TitleBarRoot"
            Height="40"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{StaticResource SamtHairlineBrush}"
            BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border x:Name="TitleBarDrag" Background="Transparent" VerticalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="14,0,8,0">
                    <TextBlock
                        FontFamily="{StaticResource SamtDisplayFont}"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource SamtGoldBrush}"
                        VerticalAlignment="Center"
                        Text="سَمت" />
                    <TextBlock
                        FontFamily="{StaticResource SamtUiFont}"
                        FontSize="11"
                        Opacity="0.55"
                        VerticalAlignment="Center"
                        Text="SAMT" />
                </StackPanel>
            </Border>
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                Spacing="0"
                VerticalAlignment="Stretch">
                <Button x:Name="TitleMinButton">
                    <FontIcon Glyph="&#xE921;" FontSize="12" />
                </Button>
                <Button x:Name="TitleMaxButton">
                    <FontIcon Glyph="&#xE922;" FontSize="12" />
                </Button>
                <Button x:Name="TitleCloseButton">
                    <FontIcon Glyph="&#xE8BB;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <NavigationView
                x:Name="NavView"
                FontFamily="{StaticResource SamtUiFont}"
                IsBackButtonVisible="Collapsed"
                IsSettingsVisible="False"
                PaneDisplayMode="Left"
                OpenPaneLength="220"
                CompactPaneLength="52"
                IsPaneOpen="False"
                PaneOpened="NavView_OnPaneOpened"
                PaneClosed="NavView_OnPaneClosed"
                DisplayModeChanged="NavView_OnDisplayModeChanged"
                SelectionChanged="NavView_OnSelectionChanged"
                Loaded="NavView_OnLoaded">
                <NavigationView.MenuItems>
                    <NavigationViewItem x:Name="NavToday" Tag="today" IsSelected="True">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE80F;" Foreground="{StaticResource SamtGoldBrush}" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem x:Name="NavLocations" Tag="locations">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE707;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem x:Name="NavAlerts" Tag="alerts">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xEA8F;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem x:Name="NavAdhkar" Tag="adhkar">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE8D7;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem x:Name="NavSettings" Tag="settings">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE713;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem x:Name="NavDiagnostics" Tag="diagnostics">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE9D9;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                    <NavigationViewItem x:Name="NavDesignLab" Tag="designlab">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE790;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </NavigationView.MenuItems>

                <NavigationView.PaneFooter>
                    <StackPanel x:Name="PaneFooterExpanded" Padding="12,8,12,14" Spacing="8">
                        <StackPanel Spacing="0" Margin="0,0,0,2">
                            <TextBlock
                                FontFamily="{StaticResource SamtDisplayFont}"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SamtGoldBrush}"
                                HorizontalAlignment="Center"
                                Text="سَمت" />
                            <TextBlock
                                FontFamily="{StaticResource SamtUiFont}"
                                FontSize="10"
                                CharacterSpacing="80"
                                Opacity="0.55"
                                HorizontalAlignment="Center"
                                Text="SAMT" />
                        </StackPanel>
                        <Button
                            x:Name="ExitAppButton"
                            HorizontalAlignment="Stretch"
                            Click="ExitAppButton_OnClick"
                            FontFamily="{StaticResource SamtUiFont}"
                            FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE7E8;" FontSize="14" />
                                <TextBlock x:Name="ExitAppButtonLabel" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </NavigationView.PaneFooter>

                <Frame x:Name="ContentFrame" />
            </NavigationView>

            <Border
                x:Name="CompactChrome"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="8,0,0,10"
                Width="44"
                Visibility="Collapsed"
                Background="Transparent"
                Canvas.ZIndex="10">
                <StackPanel Spacing="4" HorizontalAlignment="Center">
                    <Button
                        x:Name="CompactExitButton"
                        Width="36"
                        Height="32"
                        Padding="0"
                        Click="ExitAppButton_OnClick"
                        ToolTipService.ToolTip="Exit">
                        <FontIcon Glyph="&#xE7E8;" FontSize="13" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
