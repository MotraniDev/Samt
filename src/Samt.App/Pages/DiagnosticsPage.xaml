<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Samt_App.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock x:Name="TitleText" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource SamtGoldBrush}" />
            <TextBlock x:Name="PhaseText" FontSize="12" Opacity="0.65" Text="{x:Bind ViewModel.PhaseBanner, Mode=OneWay}" />
        </StackPanel>

        <Border Grid.Row="1" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{StaticResource SamtGoldBrush}" BorderThickness="1" CornerRadius="12">
            <Grid ColumnSpacing="16" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock x:Name="InputsHeader" Grid.ColumnSpan="4" FontWeight="SemiBold" />

                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                    <TextBlock x:Name="LocationLabel" Opacity="0.75" />
                    <ComboBox HorizontalAlignment="Stretch" DisplayMemberPath="DisplayName"
                              ItemsSource="{x:Bind ViewModel.Locations, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedLocation, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                    <TextBlock x:Name="MethodLabel" Opacity="0.75" />
                    <ComboBox HorizontalAlignment="Stretch" DisplayMemberPath="DisplayName"
                              ItemsSource="{x:Bind ViewModel.Methods}"
                              SelectedItem="{x:Bind ViewModel.SelectedMethod, Mode=TwoWay}" />
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4">
                    <TextBlock x:Name="DateLabel" Opacity="0.75" />
                    <CalendarDatePicker
                        Style="{StaticResource LatinDigitsCalendar}"
                        HorizontalAlignment="Stretch"
                        Date="{x:Bind ViewModel.SelectedDate, Mode=TwoWay}" />
                </StackPanel>
                <Button x:Name="RecalculateButton" Grid.Row="1" Grid.Column="3" VerticalAlignment="Bottom"
                        Click="RecalculateButton_OnClick" />

                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2">
                    <TextBlock x:Name="LatLabel" Opacity="0.75" />
                    <TextBlock
                        Style="{StaticResource LatinDigitsTextBlock}"
                        Text="{x:Bind ViewModel.LatitudeText, Mode=OneWay}" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                    <TextBlock x:Name="LonLabel" Opacity="0.75" />
                    <TextBlock
                        Style="{StaticResource LatinDigitsTextBlock}"
                        Text="{x:Bind ViewModel.LongitudeText, Mode=OneWay}" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Spacing="2">
                    <TextBlock x:Name="TzLabel" Opacity="0.75" />
                    <TextBlock
                        Style="{StaticResource LatinDigitsTextBlock}"
                        Text="{x:Bind ViewModel.TimeZoneText, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock x:Name="AsrLabel" VerticalAlignment="Center" />
                <RadioButton x:Name="AsrStandardRadio" GroupName="Asr" IsChecked="True" Checked="AsrStandardRadio_OnChecked" />
                <RadioButton x:Name="AsrHanafiRadio" GroupName="Asr" Checked="AsrHanafiRadio_OnChecked" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock x:Name="HijriOffsetLabel" VerticalAlignment="Center" />
                <NumberBox
                    x:Name="HijriOffsetBox"
                    Language="en-US"
                    FontFamily="{StaticResource SamtNumericFont}"
                    Minimum="-3"
                    Maximum="3"
                    SmallChange="1"
                    LargeChange="1"
                    SpinButtonPlacementMode="Inline"
                    Width="140"
                    Value="{x:Bind ViewModel.HijriDayOffset, Mode=TwoWay}"
                    ValueChanged="HijriOffsetBox_OnValueChanged" />
                <TextBlock
                    x:Name="HijriOffsetHint"
                    VerticalAlignment="Center"
                    Opacity="0.65"
                    FontSize="12"
                    TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="3" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="ResultsHeader" FontWeight="SemiBold" />
                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:PrayerTimeRow">
                            <Grid Padding="4,8" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Name}" FontSize="16" />
                                <TextBlock
                                    Grid.Column="1"
                                    Style="{StaticResource LatinDigitsTextBlock}"
                                    HorizontalAlignment="Center"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource SamtGoldBrush}"
                                    Text="{x:Bind DisplayTime}" />
                                <TextBlock
                                    Grid.Column="2"
                                    Style="{StaticResource LatinDigitsTextBlock}"
                                    HorizontalAlignment="Center"
                                    Opacity="0.55"
                                    Text="{x:Bind RawTime}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <TextBlock x:Name="DisclaimerText" Grid.Row="4" FontSize="12" Opacity="0.7" TextWrapping="Wrap"
                   Text="{x:Bind ViewModel.Disclaimer, Mode=OneWay}" />
    </Grid>
</Page>
