<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Samt_App.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    FontFamily="{StaticResource SamtUiFont}">

    <ScrollViewer
        Padding="20,16"
        HorizontalScrollMode="Disabled"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto"
        ZoomMode="Disabled">
        <StackPanel MaxWidth="960" HorizontalAlignment="Stretch" Spacing="16">
            <StackPanel Spacing="4">
                <TextBlock x:Name="TitleText" Style="{StaticResource SamtPageTitle}" FontSize="26" TextWrapping="Wrap" />
                <TextBlock x:Name="PhaseText" Style="{StaticResource SamtBody}" FontSize="12" Opacity="0.65"
                           Text="{x:Bind ViewModel.PhaseBanner, Mode=OneWay}" TextWrapping="Wrap" />
            </StackPanel>

            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="InputsHeader" FontWeight="SemiBold" TextWrapping="Wrap" />

                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="120" />
                            <ColumnDefinition Width="*" MinWidth="120" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="LocationLabel" Opacity="0.75" />
                            <ComboBox HorizontalAlignment="Stretch" DisplayMemberPath="DisplayName"
                                      ItemsSource="{x:Bind ViewModel.Locations, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedLocation, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock x:Name="MethodLabel" Opacity="0.75" />
                            <ComboBox HorizontalAlignment="Stretch" DisplayMemberPath="DisplayName"
                                      ItemsSource="{x:Bind ViewModel.Methods}"
                                      SelectedItem="{x:Bind ViewModel.SelectedMethod, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                            <TextBlock x:Name="DateLabel" Opacity="0.75" />
                            <CalendarDatePicker
                                Style="{StaticResource LatinDigitsCalendar}"
                                HorizontalAlignment="Stretch"
                                Date="{x:Bind ViewModel.SelectedDate, Mode=TwoWay}" />
                        </StackPanel>
                        <Button x:Name="RecalculateButton" Grid.Row="1" Grid.Column="1"
                                VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                Click="RecalculateButton_OnClick" />

                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2">
                            <TextBlock x:Name="LatLabel" Opacity="0.75" />
                            <TextBlock
                                Style="{StaticResource LatinDigitsTextBlock}"
                                Text="{x:Bind ViewModel.LatitudeText, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                            <TextBlock x:Name="LonLabel" Opacity="0.75" />
                            <TextBlock
                                Style="{StaticResource LatinDigitsTextBlock}"
                                Text="{x:Bind ViewModel.LongitudeText, Mode=OneWay}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="2">
                        <TextBlock x:Name="TzLabel" Opacity="0.75" />
                        <TextBlock
                            Style="{StaticResource LatinDigitsTextBlock}"
                            Text="{x:Bind ViewModel.TimeZoneText, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock x:Name="AsrLabel" VerticalAlignment="Center" TextWrapping="Wrap" />
                    <RadioButton x:Name="AsrStandardRadio" GroupName="Asr" IsChecked="True" Checked="AsrStandardRadio_OnChecked" />
                    <RadioButton x:Name="AsrHanafiRadio" GroupName="Asr" Checked="AsrHanafiRadio_OnChecked" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock x:Name="HijriOffsetLabel" VerticalAlignment="Center" TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="HijriOffsetValue"
                        Style="{StaticResource LatinDigitsTextBlock}"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource SamtGoldBrush}"
                        Text="{x:Bind ViewModel.HijriDayOffset, Mode=OneWay}" />
                    <TextBlock
                        x:Name="HijriOffsetHint"
                        VerticalAlignment="Center"
                        Opacity="0.65"
                        FontSize="12"
                        TextWrapping="Wrap" />
                </StackPanel>

                <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="ProcessStatusHeader" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock
                            x:Name="ProcessStatusText"
                            Style="{StaticResource LatinDigitsTextBlock}"
                            Opacity="0.75"
                            FontSize="12"
                            TextWrapping="Wrap"
                            Text="{x:Bind ViewModel.ProcessStatusText, Mode=OneWay}" />
                        <Button x:Name="RefreshStatusButton" HorizontalAlignment="Stretch"
                                Click="RefreshStatusButton_OnClick" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12"
                    MinHeight="200">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ResultsHeader" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
                        SelectionMode="None"
                        MinHeight="160"
                        MaxHeight="420"
                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:PrayerTimeRow">
                                <Grid Padding="4,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="72" />
                                        <ColumnDefinition Width="Auto" MinWidth="72" />
                                        <ColumnDefinition Width="Auto" MinWidth="72" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind Name}" FontSize="16" TextWrapping="Wrap" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Style="{StaticResource LatinDigitsTextBlock}"
                                        HorizontalAlignment="Center"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource SamtGoldBrush}"
                                        Text="{x:Bind DisplayTime}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Style="{StaticResource LatinDigitsTextBlock}"
                                        HorizontalAlignment="Center"
                                        Opacity="0.55"
                                        Text="{x:Bind RawTime}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <TextBlock x:Name="DisclaimerText" FontSize="12" Opacity="0.7" TextWrapping="Wrap"
                       Text="{x:Bind ViewModel.Disclaimer, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</Page>
