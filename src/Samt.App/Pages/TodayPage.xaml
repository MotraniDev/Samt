<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.TodayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Samt_App.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!-- frontend-design: signature = gold countdown on navy hero; quiet list below -->
    <ScrollViewer Padding="28">
        <StackPanel Spacing="20" MaxWidth="680" HorizontalAlignment="Stretch">

            <!-- Header -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock x:Name="TitleText" Style="{StaticResource SamtPageTitle}" />
                    <TextBlock
                        x:Name="LocationText"
                        Style="{StaticResource SamtBody}"
                        FontSize="16"
                        Text="{x:Bind ViewModel.LocationName, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource LatinDigitsTextBlock}"
                        FontSize="12"
                        Opacity="0.65"
                        Text="{x:Bind ViewModel.DateText, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource LatinDigitsTextBlock}"
                        FontSize="12"
                        Opacity="0.75"
                        Foreground="{StaticResource SamtGoldBrush}"
                        Text="{x:Bind ViewModel.HijriDateText, Mode=OneWay}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                    <Border
                        Padding="10,6"
                        CornerRadius="999"
                        Background="{StaticResource SamtCardBrush}"
                        BorderBrush="{StaticResource SamtGoldBrush}"
                        BorderThickness="1">
                        <TextBlock
                            Style="{StaticResource SamtSectionLabel}"
                            Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
                    </Border>
                    <Border
                        Padding="10,4"
                        CornerRadius="999"
                        Background="{StaticResource SamtGoldBrush}"
                        Visibility="{x:Bind ViewModel.RamadanBadgeVisibility, Mode=OneWay}">
                        <TextBlock
                            x:Name="RamadanBadgeText"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SamtNavyBrush}"
                            HorizontalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Signature hero -->
            <Border CornerRadius="20" Padding="28,32" Background="{StaticResource SamtHeroGradient}">
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <TextBlock
                        x:Name="NextLabel"
                        Style="{StaticResource SamtSectionLabel}"
                        Foreground="{StaticResource SamtIvoryBrush}"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        FontFamily="{StaticResource SamtUiFont}"
                        FontSize="34"
                        FontWeight="Bold"
                        Foreground="{StaticResource SamtIvoryBrush}"
                        HorizontalAlignment="Center"
                        Text="{x:Bind ViewModel.NextPrayerName, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource SamtCountdownText}"
                        Text="{x:Bind ViewModel.CountdownText, Mode=OneWay}" />
                    <TextBlock
                        Style="{StaticResource LatinDigitsTextBlock}"
                        FontSize="16"
                        Foreground="{StaticResource SamtGoldSoftBrush}"
                        Opacity="0.9"
                        HorizontalAlignment="Center"
                        Text="{x:Bind ViewModel.NextPrayerTime, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <!-- Prayer timeline list -->
            <StackPanel Spacing="8">
                <TextBlock x:Name="TimesHeader" Style="{StaticResource SamtSectionLabel}" />
                <Border
                    CornerRadius="16"
                    Padding="4,8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PrayerTimeRow">
                                <Grid Padding="16,12" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="96" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Grid.Column="0"
                                        CornerRadius="2"
                                        Background="{StaticResource SamtGoldBrush}"
                                        Visibility="{x:Bind NextMarkerVisibility}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Style="{StaticResource SamtBody}"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind Name}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Style="{StaticResource SamtPrayerRowTime}"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind DisplayTime}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>

            <!-- Qibla (static bearing from coordinates) -->
            <Border
                CornerRadius="16"
                Padding="16,14"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="QiblaHeader" Style="{StaticResource SamtSectionLabel}" />
                        <TextBlock
                            Style="{StaticResource LatinDigitsTextBlock}"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SamtGoldBrush}"
                            Text="{x:Bind ViewModel.QiblaBearingText, Mode=OneWay}" />
                        <TextBlock
                            Style="{StaticResource LatinDigitsTextBlock}"
                            FontSize="12"
                            Opacity="0.65"
                            Text="{x:Bind ViewModel.QiblaDistanceText, Mode=OneWay}" />
                    </StackPanel>
                    <FontIcon
                        Grid.Column="1"
                        Glyph="&#xE909;"
                        FontSize="28"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource SamtGoldSoftBrush}"
                        Opacity="0.85" />
                </Grid>
            </Border>

            <TextBlock
                x:Name="DisclaimerText"
                Style="{StaticResource SamtBody}"
                FontSize="12"
                Opacity="0.6"
                TextWrapping="Wrap"
                Text="{x:Bind ViewModel.Disclaimer, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</Page>
