<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.TodayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Samt_App.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Stretch">
            <StackPanel Spacing="4">
                <TextBlock x:Name="TitleText" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource SamtGoldBrush}" />
                <TextBlock x:Name="DateText" Opacity="0.8" Text="{x:Bind ViewModel.DateText, Mode=OneWay}" FontFamily="Consolas" />
                <TextBlock x:Name="LocationText" Text="{x:Bind ViewModel.LocationName, Mode=OneWay}" FontSize="16" />
                <TextBlock Opacity="0.7" FontFamily="Consolas" Text="{x:Bind ViewModel.CoordinatesText, Mode=OneWay}" />
            </StackPanel>

            <Border Padding="20" CornerRadius="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SamtGoldBrush}" BorderThickness="1">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock x:Name="NextLabel" Opacity="0.75" HorizontalAlignment="Center" />
                    <TextBlock FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"
                               Text="{x:Bind ViewModel.NextPrayerName, Mode=OneWay}" />
                    <TextBlock FontSize="40" FontFamily="Consolas" FontWeight="SemiBold"
                               Foreground="{StaticResource SamtGoldBrush}" HorizontalAlignment="Center"
                               Text="{x:Bind ViewModel.CountdownText, Mode=OneWay}" />
                    <TextBlock FontFamily="Consolas" HorizontalAlignment="Center" Opacity="0.85"
                               Text="{x:Bind ViewModel.NextPrayerTime, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="StatusText" Opacity="0.75" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />

            <Border Padding="12" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <ListView ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:PrayerTimeRow">
                            <Grid Padding="4,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Name}" FontSize="16" />
                                <TextBlock Grid.Column="1" Text="{x:Bind DisplayTime}" FontFamily="Consolas"
                                           FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource SamtGoldBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <TextBlock x:Name="DisclaimerText" FontSize="12" Opacity="0.7" TextWrapping="Wrap"
                       Text="{x:Bind ViewModel.Disclaimer, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</Page>
