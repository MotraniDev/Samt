<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.TodayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Samt_App.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    FontFamily="{StaticResource SamtUiFont}">

    <!-- Stitch Night Mosque: gold countdown on navy hero; geometric corner ornaments; quiet list -->
    <ScrollViewer x:Name="RootScroll" Padding="20,16" HorizontalScrollMode="Disabled">
        <StackPanel x:Name="ContentRoot" Spacing="14" HorizontalAlignment="Stretch">

            <!-- Header -->
            <Grid x:Name="HeaderGrid" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2">
                    <TextBlock x:Name="TitleText" Style="{StaticResource SamtPageTitle}" />
                    <TextBlock
                        x:Name="LocationText"
                        Style="{StaticResource SamtBody}"
                        FontSize="15"
                        FontWeight="Medium"
                        TextWrapping="Wrap"
                        Text="{x:Bind ViewModel.LocationName, Mode=OneWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            Style="{StaticResource LatinDigitsTextBlock}"
                            FontSize="12"
                            Opacity="0.65"
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.DateText, Mode=OneWay}" />
                        <TextBlock
                            FontFamily="{StaticResource SamtUiFont}"
                            FontSize="12"
                            Opacity="0.35"
                            VerticalAlignment="Center"
                            Text="·" />
                        <TextBlock
                            Style="{StaticResource LatinDigitsTextBlock}"
                            FontFamily="{StaticResource SamtUiFont}"
                            FontSize="12"
                            FontWeight="Medium"
                            Opacity="0.9"
                            Foreground="{StaticResource SamtGoldBrush}"
                            VerticalAlignment="Center"
                            Text="{x:Bind ViewModel.HijriDateText, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel
                    x:Name="MethodChromeStack"
                    Grid.Column="1"
                    Spacing="6"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,0,44,0">
                    <!-- Calculation method circle (e.g. Algeria 18°/17°) — compact, centered text -->
                    <Border
                        x:Name="MethodCircle"
                        Width="92"
                        Height="92"
                        CornerRadius="46"
                        Padding="8"
                        Background="{StaticResource SamtCardBrush}"
                        BorderBrush="{StaticResource SamtGoldBrush}"
                        BorderThickness="1.5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top">
                        <TextBlock
                            x:Name="MethodCircleText"
                            Style="{StaticResource LatinDigitsTextBlock}"
                            FontFamily="{StaticResource SamtUiFont}"
                            FontSize="10"
                            FontWeight="SemiBold"
                            LineHeight="13"
                            CharacterSpacing="-20"
                            Foreground="{StaticResource SamtGoldSoftBrush}"
                            Opacity="1"
                            TextWrapping="WrapWholeWords"
                            TextAlignment="Center"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxLines="4"
                            Text="{x:Bind ViewModel.MethodCircleText, Mode=OneWay}" />
                    </Border>
                    <Border
                        Padding="10,4"
                        CornerRadius="999"
                        Background="{StaticResource SamtGoldBrush}"
                        HorizontalAlignment="Center"
                        Visibility="{x:Bind ViewModel.RamadanBadgeVisibility, Mode=OneWay}">
                        <TextBlock
                            x:Name="RamadanBadgeText"
                            FontFamily="{StaticResource SamtDisplayFont}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SamtNavyBrush}"
                            HorizontalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Signature hero with subtle geometric corner ornaments -->
            <Border x:Name="HeroCard" CornerRadius="16" Padding="0" Background="{StaticResource SamtHeroGradient}"
                    BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1">
                <Grid x:Name="HeroGrid" MinHeight="160">
                    <!-- Corner ornaments (Islamic geometry, low opacity) -->
                    <Path
                        x:Name="OrnamentTop"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,10,0"
                        Width="44"
                        Height="44"
                        Stretch="Uniform"
                        Stroke="{StaticResource SamtOrnamentBrush}"
                        StrokeThickness="1.25"
                        Data="M 0,0 L 56,0 L 56,14 M 0,0 L 0,56 L 14,56 M 0,0 L 40,40" />
                    <Path
                        x:Name="OrnamentBottom"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="10,0,0,10"
                        Width="44"
                        Height="44"
                        Stretch="Uniform"
                        Stroke="{StaticResource SamtOrnamentBrush}"
                        StrokeThickness="1.25"
                        Data="M 56,56 L 0,56 L 0,42 M 56,56 L 56,0 L 42,0 M 56,56 L 16,16" />

                    <StackPanel
                        x:Name="HeroContent"
                        Spacing="6"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="16,24">
                        <TextBlock
                            x:Name="NextLabel"
                            Style="{StaticResource SamtSectionLabel}"
                            Foreground="{StaticResource SamtIvoryMutedBrush}"
                            Opacity="0.85"
                            HorizontalAlignment="Center" />
                        <TextBlock
                            x:Name="NextPrayerNameText"
                            Style="{StaticResource SamtDisplayText}"
                            FontSize="32"
                            HorizontalAlignment="Center"
                            TextWrapping="Wrap"
                            TextAlignment="Center"
                            Text="{x:Bind ViewModel.NextPrayerName, Mode=OneWay}" />
                        <TextBlock
                            x:Name="CountdownTextBlock"
                            Style="{StaticResource SamtCountdownText}"
                            FontSize="36"
                            Text="{x:Bind ViewModel.CountdownText, Mode=OneWay}" />
                        <TextBlock
                            Style="{StaticResource LatinDigitsTextBlock}"
                            FontSize="15"
                            Foreground="{StaticResource SamtGoldSoftBrush}"
                            Opacity="0.9"
                            HorizontalAlignment="Center"
                            Text="{x:Bind ViewModel.NextPrayerTime, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Prayer timeline list -->
            <StackPanel Spacing="6">
                <TextBlock x:Name="TimesHeader" Style="{StaticResource SamtSectionLabel}"
                           Foreground="{StaticResource SamtGoldBrush}" Opacity="0.85" />
                <Border
                    CornerRadius="14"
                    Padding="2,4"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SamtHairlineBrush}"
                    BorderThickness="1">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PrayerTimeRow">
                                <!-- Half the previous vertical gap between prayer rows -->
                                <Grid Padding="12,6" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Grid.Column="0"
                                        CornerRadius="2"
                                        Background="{StaticResource SamtGoldBrush}"
                                        Visibility="{x:Bind NextMarkerVisibility}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        FontFamily="{StaticResource SamtUiFont}"
                                        FontSize="15"
                                        FontWeight="Medium"
                                        VerticalAlignment="Center"
                                        TextTrimming="CharacterEllipsis"
                                        Text="{x:Bind Name}" />
                                    <!-- Manual-edit badge -->
                                    <Border
                                        Grid.Column="2"
                                        Padding="6,2"
                                        CornerRadius="6"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource SamtGoldBrush}"
                                        Opacity="0.9"
                                        Visibility="{x:Bind ManualBadgeVisibility}">
                                        <TextBlock
                                            FontFamily="{StaticResource SamtUiFont}"
                                            FontSize="10"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource SamtNavyBrush}"
                                            Text="✎" />
                                    </Border>
                                    <Button
                                        Grid.Column="3"
                                        Padding="8,2"
                                        MinWidth="72"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Tag="{x:Bind Event}"
                                        Click="PrayerTime_OnClick"
                                        ToolTipService.ToolTip="Edit">
                                        <TextBlock
                                            Style="{StaticResource SamtPrayerRowTime}"
                                            FontSize="15"
                                            Text="{x:Bind DisplayTime}" />
                                    </Button>
                                    <Button
                                        Grid.Column="4"
                                        Padding="4"
                                        MinWidth="28"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Tag="{x:Bind Event}"
                                        Visibility="{x:Bind ManualBadgeVisibility}"
                                        Click="ResetPrayerTime_OnClick"
                                        ToolTipService.ToolTip="Reset">
                                        <FontIcon Glyph="&#xE149;" FontSize="12" Opacity="0.7" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>

            <!-- Qibla -->
            <Border
                x:Name="QiblaCard"
                CornerRadius="14"
                Padding="14,12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{StaticResource SamtHairlineBrush}"
                BorderThickness="1">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="QiblaHeader" Style="{StaticResource SamtSectionLabel}"
                                   Foreground="{StaticResource SamtGoldBrush}" Opacity="0.85" />
                        <TextBlock
                            Style="{StaticResource LatinDigitsTextBlock}"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SamtGoldBrush}"
                            TextWrapping="Wrap"
                            Text="{x:Bind ViewModel.QiblaBearingText, Mode=OneWay}" />
                        <TextBlock
                            Style="{StaticResource LatinDigitsTextBlock}"
                            FontSize="12"
                            Opacity="0.65"
                            Text="{x:Bind ViewModel.QiblaDistanceText, Mode=OneWay}" />
                    </StackPanel>
                    <Border
                        Grid.Column="1"
                        Width="40"
                        Height="40"
                        CornerRadius="20"
                        Background="{StaticResource SamtCardBrush}"
                        BorderBrush="{StaticResource SamtHairlineBrush}"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                        <FontIcon
                            Glyph="&#xE909;"
                            FontSize="18"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource SamtGoldSoftBrush}" />
                    </Border>
                </Grid>
            </Border>

            <TextBlock
                x:Name="DisclaimerText"
                Style="{StaticResource SamtBody}"
                FontSize="11"
                Opacity="0.55"
                TextWrapping="Wrap"
                Text="{x:Bind ViewModel.Disclaimer, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>

    <!-- Time edit dialog content is built in code-behind -->
</Page>
