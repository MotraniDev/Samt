<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.DesignLabPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
      PROTOTYPE — toast/overlay look + motion + opacity.
      Play animation; tune opacity; pick A/B/C.
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Stage -->
        <Grid x:Name="Stage" Background="#33000000">
            <Border
                x:Name="ToastCard"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="24,40,24,0"
                Padding="20,16"
                CornerRadius="14"
                BorderBrush="{StaticResource SamtGoldBrush}"
                BorderThickness="1"
                MaxWidth="440"
                MinWidth="280"
                Opacity="0.92"
                RenderTransformOrigin="0.5,0.5">
                <Border.Background>
                    <SolidColorBrush x:Name="ToastBgBrush" Color="#0B1F33" Opacity="0.92" />
                </Border.Background>
                <Border.RenderTransform>
                    <CompositeTransform x:Name="ToastTransform" TranslateY="-80" />
                </Border.RenderTransform>
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock
                            x:Name="ToastTitle"
                            Text="الفجر"
                            Foreground="{StaticResource SamtIvoryBrush}"
                            FontSize="20"
                            FontWeight="SemiBold" />
                        <TextBlock
                            x:Name="ToastTime"
                            Style="{StaticResource LatinDigitsTextBlock}"
                            Text="05:12"
                            Foreground="{StaticResource SamtGoldSoftBrush}"
                            FontSize="28" />
                        <TextBlock
                            x:Name="ToastSubtitle"
                            Text="دخل وقت الصلاة"
                            Foreground="{StaticResource SamtIvoryBrush}"
                            Opacity="0.75"
                            FontSize="13" />
                    </StackPanel>
                    <Button
                        x:Name="StopBtn"
                        Grid.Column="1"
                        Content="إيقاف"
                        VerticalAlignment="Center"
                        Click="StopBtn_OnClick" />
                </Grid>
            </Border>
        </Grid>

        <!-- Controls -->
        <Border
            Grid.Row="1"
            Margin="12"
            Padding="16"
            CornerRadius="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{StaticResource SamtGoldBrush}"
            BorderThickness="1">
            <StackPanel Spacing="12">
                <TextBlock x:Name="LabLabel" FontWeight="SemiBold" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock VerticalAlignment="Center" Text="Style" Opacity="0.75" Width="80" />
                    <Button x:Name="BtnA" Content="A Top" Click="VariantButton_OnClick" Tag="A" />
                    <Button x:Name="BtnB" Content="B Bottom" Click="VariantButton_OnClick" Tag="B" />
                    <Button x:Name="BtnC" Content="C Edge" Click="VariantButton_OnClick" Tag="C" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock VerticalAlignment="Center" Text="Motion" Opacity="0.75" Width="80" />
                    <ComboBox x:Name="EdgeBox" MinWidth="140" SelectionChanged="EdgeBox_OnSelectionChanged">
                        <ComboBoxItem Content="From top" Tag="Top" IsSelected="True" />
                        <ComboBoxItem Content="From bottom" Tag="Bottom" />
                        <ComboBoxItem Content="From start" Tag="Start" />
                        <ComboBoxItem Content="From end" Tag="End" />
                    </ComboBox>
                    <Button x:Name="PlayBtn" Content="Play" Click="PlayBtn_OnClick" Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Name="FireToastBtn" Content="Fire tray toast" Click="FireToastBtn_OnClick" />
                </StackPanel>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="56" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Opacity" Opacity="0.75" />
                    <Slider
                        x:Name="OpacitySlider"
                        Grid.Column="1"
                        Minimum="30"
                        Maximum="100"
                        Value="92"
                        StepFrequency="1"
                        ValueChanged="OpacitySlider_OnValueChanged" />
                    <TextBlock
                        x:Name="OpacityValueText"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Style="{StaticResource LatinDigitsTextBlock}"
                        Text="92%" />
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="56" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Duration" Opacity="0.75" />
                    <Slider
                        x:Name="DurationSlider"
                        Grid.Column="1"
                        Minimum="150"
                        Maximum="900"
                        Value="320"
                        StepFrequency="10"
                        ValueChanged="DurationSlider_OnValueChanged" />
                    <TextBlock
                        x:Name="DurationValueText"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Style="{StaticResource LatinDigitsTextBlock}"
                        Text="320ms" />
                </Grid>

                <TextBlock
                    x:Name="HintText"
                    FontSize="12"
                    Opacity="0.65"
                    TextWrapping="Wrap"
                    Text="Play runs entrance motion. Opacity applies to the card. Fire tray toast tests the balloon fallback." />
            </StackPanel>
        </Border>
    </Grid>
</Page>
