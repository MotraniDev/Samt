<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.DesignLabPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
      PROTOTYPE — toast/overlay look + motion + opacity.
      Play animation; tune opacity; pick A/B/C.
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Stage -->
        <Grid x:Name="Stage" Background="#33000000">
            <Border
                x:Name="ToastCard"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="24,40,24,0"
                Padding="0"
                CornerRadius="16"
                BorderBrush="{StaticResource SamtGoldSoftBrush}"
                BorderThickness="1.5"
                MaxWidth="480"
                MinWidth="300"
                Opacity="0.94"
                RenderTransformOrigin="0.5,0.5">
                <Border.Background>
                    <SolidColorBrush x:Name="ToastBgBrush" Color="#071525" Opacity="0.96" />
                </Border.Background>
                <Border.RenderTransform>
                    <CompositeTransform x:Name="ToastTransform" TranslateY="-80" />
                </Border.RenderTransform>
                <Grid>
                    <Image
                        Source="ms-appx:///Assets/Textures/islamic-tile.png"
                        Stretch="UniformToFill"
                        Opacity="0.42"
                        IsHitTestVisible="False" />
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#CC071525" Offset="0" />
                                <GradientStop Color="#9914324F" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Grid x:Name="ToastContentPanel" Padding="22,16" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="ToastTextStack" Spacing="4">
                            <TextBlock
                                x:Name="ToastEyebrow"
                                FontFamily="{StaticResource SamtUiFont}"
                                Text="موعد الأذان"
                                Foreground="{StaticResource SamtGoldSoftBrush}"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Opacity="0.8" />
                            <TextBlock
                                x:Name="ToastTitle"
                                Text="الفجر"
                                FontFamily="{StaticResource SamtDisplayFont}"
                                Foreground="{StaticResource SamtIvoryBrush}"
                                FontSize="26"
                                FontWeight="Bold" />
                            <TextBlock
                                x:Name="ToastTime"
                                Style="{StaticResource LatinDigitsTextBlock}"
                                Text="05:12"
                                Foreground="{StaticResource SamtGoldBrightBrush}"
                                FontSize="30" />
                            <TextBlock
                                x:Name="ToastSubtitle"
                                Text="حان موعد الأذان"
                                FontFamily="{StaticResource SamtNaskhFont}"
                                Foreground="{StaticResource SamtIvoryBrush}"
                                Opacity="0.85"
                                FontSize="14" />
                        </StackPanel>
                        <Button
                            x:Name="StopBtn"
                            Grid.Column="1"
                            Content="إيقاف"
                            FontFamily="{StaticResource SamtUiFont}"
                            FontSize="14"
                            VerticalAlignment="Center"
                            Click="StopBtn_OnClick" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Controls -->
        <Border
            Grid.Row="1"
            Margin="12"
            Padding="16"
            CornerRadius="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{StaticResource SamtGoldBrush}"
            BorderThickness="1">
            <StackPanel Spacing="12">
                <TextBlock x:Name="LabLabel" FontWeight="SemiBold" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock VerticalAlignment="Center" Text="Style" Opacity="0.75" Width="80" />
                    <Button x:Name="BtnA" Content="A Top" Click="VariantButton_OnClick" Tag="A" />
                    <Button x:Name="BtnB" Content="B Bottom" Click="VariantButton_OnClick" Tag="B" />
                    <Button x:Name="BtnC" Content="C Edge" Click="VariantButton_OnClick" Tag="C" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock VerticalAlignment="Center" Text="Motion" Opacity="0.75" Width="80" />
                    <ComboBox x:Name="EdgeBox" MinWidth="140" SelectionChanged="EdgeBox_OnSelectionChanged">
                        <ComboBoxItem Content="From top" Tag="Top" IsSelected="True" />
                        <ComboBoxItem Content="From bottom" Tag="Bottom" />
                        <ComboBoxItem Content="From start" Tag="Start" />
                        <ComboBoxItem Content="From end" Tag="End" />
                    </ComboBox>
                    <Button x:Name="PlayBtn" Content="Play" Click="PlayBtn_OnClick" Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Name="FireToastBtn" Content="Fire tray toast" Click="FireToastBtn_OnClick" />
                    <Button x:Name="FireOverlayBtn" Content="Fire overlay+audio" Click="FireOverlayBtn_OnClick" />
                    <Button x:Name="FirePreAlertBtn" Content="Fire pre-alert" Click="FirePreAlertBtn_OnClick" />
                </StackPanel>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="56" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Opacity" Opacity="0.75" />
                    <!-- Numeric range set in code-behind: XAML Min/Max order + culture parsing crash LoadComponent. -->
                    <Slider
                        x:Name="OpacitySlider"
                        Grid.Column="1"
                        Language="en-US"
                        ValueChanged="OpacitySlider_OnValueChanged" />
                    <TextBlock
                        x:Name="OpacityValueText"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Style="{StaticResource LatinDigitsTextBlock}"
                        Text="92%" />
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="56" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center" Text="Duration" Opacity="0.75" />
                    <Slider
                        x:Name="DurationSlider"
                        Grid.Column="1"
                        Language="en-US"
                        ValueChanged="DurationSlider_OnValueChanged" />
                    <TextBlock
                        x:Name="DurationValueText"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Style="{StaticResource LatinDigitsTextBlock}"
                        Text="320ms" />
                </Grid>

                <TextBlock
                    x:Name="HintText"
                    FontSize="12"
                    Opacity="0.65"
                    TextWrapping="Wrap"
                    Text="Play = stage mock. Opacity + Duration + Motion apply to Fire overlay+audio / Fire pre-alert (production window)." />
            </StackPanel>
        </Border>
    </Grid>
</Page>
