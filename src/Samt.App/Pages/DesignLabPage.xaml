<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.DesignLabPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
      PROTOTYPE (skill: prototype) — throwaway overlay visual variants.
      Question: What should the prayer overlay look like before Phase 4?
      Switch A / B / C below. Absorb the winner; delete this page later.
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="Stage" Background="#22000000">
            <!-- Variant A: top ribbon toast-like -->
            <Border
                x:Name="VariantA"
                Visibility="Visible"
                VerticalAlignment="Top"
                Margin="24,24,24,0"
                Padding="20,16"
                CornerRadius="14"
                Background="{StaticResource SamtHeroGradient}"
                BorderBrush="{StaticResource SamtGoldBrush}"
                BorderThickness="1"
                MaxWidth="420"
                HorizontalAlignment="Center">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock Text="الفجر" Foreground="{StaticResource SamtIvoryBrush}" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Style="{StaticResource LatinDigitsTextBlock}" Text="05:12" Foreground="{StaticResource SamtGoldSoftBrush}" FontSize="28" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="إيقاف" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Variant B: bottom dock card -->
            <Border
                x:Name="VariantB"
                Visibility="Collapsed"
                VerticalAlignment="Bottom"
                Margin="32,0,32,48"
                Padding="24,20"
                CornerRadius="24"
                Background="{StaticResource SamtNavyDeepBrush}"
                BorderBrush="{StaticResource SamtGoldBrush}"
                BorderThickness="1.5"
                MaxWidth="480"
                HorizontalAlignment="Stretch">
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock Text="دخل وقت المغرب" Foreground="{StaticResource SamtIvoryBrush}" FontSize="22" HorizontalAlignment="Center" />
                    <TextBlock Style="{StaticResource LatinDigitsTextBlock}" Text="18:28" Foreground="{StaticResource SamtGoldBrush}" FontSize="40" HorizontalAlignment="Center" />
                    <Button Content="إيقاف الأذان" HorizontalAlignment="Center" Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Border>

            <!-- Variant C: edge callout (start side) -->
            <Border
                x:Name="VariantC"
                Visibility="Collapsed"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                Margin="0,0,0,0"
                Padding="20,28"
                Width="280"
                Background="{StaticResource SamtIvoryBrush}"
                BorderBrush="{StaticResource SamtGreenBrush}"
                BorderThickness="0,0,0,0"
                CornerRadius="0,16,16,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="SAMT" Foreground="{StaticResource SamtGoldBrush}" FontWeight="Bold" />
                    <TextBlock Text="العشاء" Foreground="{StaticResource SamtNavyBrush}" FontSize="26" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource LatinDigitsTextBlock}" Text="20:05" Foreground="{StaticResource SamtGreenBrush}" FontSize="32" />
                    <TextBlock Text="اضغط Esc للإيقاف" Foreground="{StaticResource SamtNavyBrush}" Opacity="0.7" FontSize="12" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Floating prototype switcher -->
        <Border
            Grid.Row="1"
            Margin="16"
            Padding="12,10"
            CornerRadius="999"
            HorizontalAlignment="Center"
            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}"
            BorderBrush="{StaticResource SamtGoldBrush}"
            BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="LabLabel" VerticalAlignment="Center" Opacity="0.8" Margin="4,0,8,0" />
                <Button x:Name="BtnA" Content="A" Click="VariantButton_OnClick" Tag="A" />
                <Button x:Name="BtnB" Content="B" Click="VariantButton_OnClick" Tag="B" />
                <Button x:Name="BtnC" Content="C" Click="VariantButton_OnClick" Tag="C" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
