<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.AdhkarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Samt_App.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    FontFamily="{StaticResource SamtUiFont}">

    <ScrollViewer Padding="28,24">
        <StackPanel Spacing="18" MaxWidth="720">
            <StackPanel Spacing="6">
                <TextBlock x:Name="TitleText" Style="{StaticResource SamtPageTitle}" />
                <TextBlock
                    x:Name="SubtitleText"
                    Style="{StaticResource SamtBody}"
                    Opacity="0.75"
                    TextWrapping="Wrap" />
            </StackPanel>

            <ItemsControl ItemsSource="{x:Bind ViewModel.Sections, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AdhkarSection">
                        <Border
                            Margin="0,0,0,14"
                            Padding="20,18"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{StaticResource SamtHairlineBrush}"
                            BorderThickness="1">
                            <StackPanel Spacing="14">
                                <!-- Section header with gold accent bar -->
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Grid.Column="0"
                                        CornerRadius="2"
                                        Background="{StaticResource SamtGoldBrush}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        FontFamily="{StaticResource SamtDisplayFont}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource SamtGoldBrush}"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind Title}" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AdhkarItem">
                                            <StackPanel Spacing="6" Margin="0,0,0,14">
                                                <TextBlock
                                                    Style="{StaticResource SamtNaskhText}"
                                                    FontSize="22"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                    Text="{x:Bind ArabicText}" />
                                                <TextBlock
                                                    Style="{StaticResource SamtBody}"
                                                    FontSize="13"
                                                    Opacity="0.68"
                                                    TextWrapping="Wrap"
                                                    Text="{x:Bind Translation}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock
                Style="{StaticResource SamtBody}"
                FontSize="12"
                Opacity="0.55"
                TextWrapping="Wrap"
                Text="{x:Bind ViewModel.Disclaimer, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</Page>
