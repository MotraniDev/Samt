<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.AdhkarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Samt_App.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="28">
        <StackPanel Spacing="16" MaxWidth="720">
            <StackPanel Spacing="4">
                <TextBlock x:Name="TitleText" Style="{StaticResource SamtPageTitle}" />
                <TextBlock
                    x:Name="SubtitleText"
                    Style="{StaticResource SamtBody}"
                    Opacity="0.75"
                    TextWrapping="Wrap" />
            </StackPanel>

            <ItemsControl ItemsSource="{x:Bind ViewModel.Sections, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AdhkarSection">
                        <Border
                            Margin="0,0,0,12"
                            Padding="16"
                            CornerRadius="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Style="{StaticResource SamtSectionLabel}"
                                    Foreground="{StaticResource SamtGoldBrush}"
                                    Text="{x:Bind Title}" />
                                <ItemsControl ItemsSource="{x:Bind Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AdhkarItem">
                                            <StackPanel Spacing="4" Margin="0,0,0,12">
                                                <TextBlock
                                                    FontFamily="{StaticResource SamtUiFont}"
                                                    FontSize="18"
                                                    TextWrapping="Wrap"
                                                    Text="{x:Bind ArabicText}" />
                                                <TextBlock
                                                    Style="{StaticResource SamtBody}"
                                                    FontSize="13"
                                                    Opacity="0.7"
                                                    TextWrapping="Wrap"
                                                    Text="{x:Bind Translation}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock
                Style="{StaticResource SamtBody}"
                FontSize="12"
                Opacity="0.6"
                TextWrapping="Wrap"
                Text="{x:Bind ViewModel.Disclaimer, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</Page>
