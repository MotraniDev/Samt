<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.AdhkarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Samt_App.ViewModels"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    FontFamily="{StaticResource SamtUiFont}">

    <ScrollViewer
        Padding="20,16"
        HorizontalScrollMode="Disabled"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto"
        ZoomMode="Disabled">
        <StackPanel Spacing="18" MaxWidth="900" HorizontalAlignment="Stretch">
            <StackPanel Spacing="6">
                <TextBlock x:Name="TitleText" Style="{StaticResource SamtPageTitle}" TextWrapping="Wrap" />
                <TextBlock
                    x:Name="SubtitleText"
                    Style="{StaticResource SamtBody}"
                    Opacity="0.75"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="SourceText"
                    FontSize="12"
                    Opacity="0.55"
                    TextWrapping="Wrap" />
            </StackPanel>

            <ItemsControl ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AdhkarGroupVm">
                        <StackPanel Spacing="10" Margin="0,0,0,16">
                            <TextBlock
                                FontFamily="{StaticResource SamtDisplayFont}"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource SamtGoldBrush}"
                                Text="{x:Bind Title}" />
                            <ItemsControl ItemsSource="{x:Bind Sections}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AdhkarSectionVm">
                                        <Border
                                            Width="260"
                                            Margin="0,0,12,12"
                                            Padding="16,14"
                                            CornerRadius="16"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{StaticResource SamtHairlineBrush}"
                                            BorderThickness="1">
                                            <StackPanel Spacing="10">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{x:Bind Icon}" FontSize="22" VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Spacing="2">
                                                        <TextBlock
                                                            FontFamily="{StaticResource SamtDisplayFont}"
                                                            FontSize="16"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource SamtGoldBrush}"
                                                            TextWrapping="Wrap"
                                                            Text="{x:Bind Title}" />
                                                        <TextBlock
                                                            Style="{StaticResource LatinDigitsTextBlock}"
                                                            FontSize="12"
                                                            Opacity="0.65"
                                                            Text="{x:Bind CountLabel}" />
                                                    </StackPanel>
                                                </Grid>
                                                <Button
                                                    Tag="{x:Bind Kind}"
                                                    Click="OpenReaderButton_OnClick"
                                                    HorizontalAlignment="Stretch"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    FontFamily="{StaticResource SamtUiFont}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                                        <FontIcon Glyph="&#xE8D7;" FontSize="14" />
                                                        <TextBlock Text="{x:Bind OpenLabel}" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock
                Style="{StaticResource SamtBody}"
                FontSize="12"
                Opacity="0.55"
                TextWrapping="Wrap"
                Text="{x:Bind ViewModel.Disclaimer, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</Page>
