<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    FontFamily="{StaticResource SamtUiFont}">

    <ScrollViewer
        Padding="20,16"
        HorizontalScrollMode="Disabled"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto"
        ZoomMode="Disabled">
        <StackPanel MaxWidth="720" HorizontalAlignment="Stretch" Spacing="16">
            <TextBlock x:Name="TitleText" Style="{StaticResource SamtPageTitle}" FontSize="26" TextWrapping="Wrap" />

            <!-- Language -->
            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE774;" FontSize="16" Foreground="{StaticResource SamtGoldBrush}"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="LanguageSectionHeader" FontWeight="SemiBold" FontSize="16"
                                   Foreground="{StaticResource SamtGoldBrush}" TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ComboBox x:Name="LanguageBox" HorizontalAlignment="Stretch" MinWidth="120"
                              FontFamily="{StaticResource SamtUiFont}"
                              SelectionChanged="LanguageBox_OnSelectionChanged">
                        <ComboBoxItem Content="العربية" Tag="ar" />
                        <ComboBoxItem Content="English" Tag="en-US" />
                        <ComboBoxItem Content="Français" Tag="fr" />
                        <ComboBoxItem Content="Español" Tag="es" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Theme packages -->
            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE790;" FontSize="16" Foreground="{StaticResource SamtGoldBrush}"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="ThemeSectionHeader" FontWeight="SemiBold" FontSize="16"
                                   Foreground="{StaticResource SamtGoldBrush}" TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ComboBox x:Name="ThemeBox" HorizontalAlignment="Stretch" MinWidth="120"
                              FontFamily="{StaticResource SamtUiFont}"
                              SelectionChanged="ThemeBox_OnSelectionChanged">
                        <ComboBoxItem x:Name="ThemeSystemItem" Tag="system" />
                        <ComboBoxItem x:Name="ThemeLightItem" Tag="light" />
                        <ComboBoxItem x:Name="ThemeDarkItem" Tag="dark" />
                        <ComboBoxItem x:Name="ThemeRamadanItem" Tag="ramadan" />
                        <ComboBoxItem x:Name="ThemeAlgeriaItem" Tag="algeria" />
                        <ComboBoxItem x:Name="ThemeMoroccoItem" Tag="morocco" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- App options -->
            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE713;" FontSize="16" Foreground="{StaticResource SamtGoldBrush}"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="AppOptionsHeader" FontWeight="SemiBold" FontSize="16"
                                   Foreground="{StaticResource SamtGoldBrush}" TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ToggleSwitch x:Name="AutoStartToggle" Toggled="AutoStartToggle_OnToggled" />
                    <ToggleSwitch x:Name="MissedResumeToggle" Toggled="MissedResumeToggle_OnToggled" />
                </StackPanel>
            </Border>

            <!-- Updates -->
            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE895;" FontSize="16" Foreground="{StaticResource SamtGoldBrush}"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="UpdatesSectionHeader" FontWeight="SemiBold" FontSize="16"
                                   Foreground="{StaticResource SamtGoldBrush}" TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <ToggleSwitch x:Name="AutoUpdateToggle" Toggled="AutoUpdateToggle_OnToggled" />
                    <Button x:Name="CheckUpdatesButton" HorizontalAlignment="Stretch"
                            Click="CheckUpdatesButton_OnClick" />
                    <TextBlock x:Name="UpdateStatusText" Opacity="0.7" FontSize="12" TextWrapping="Wrap"
                               Style="{StaticResource LatinDigitsTextBlock}" />
                </StackPanel>
            </Border>

            <!-- Appearance: global window transparency -->
            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE793;" FontSize="16" Foreground="{StaticResource SamtGoldBrush}"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="AppearanceSectionHeader" FontWeight="SemiBold" FontSize="16"
                                   Foreground="{StaticResource SamtGoldBrush}" TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="AppearanceSectionHint" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Slider
                            x:Name="WindowOpacitySlider"
                            Grid.Column="0"
                            Minimum="30"
                            Maximum="100"
                            StepFrequency="1"
                            TickFrequency="10"
                            IsThumbToolTipEnabled="False"
                            ValueChanged="WindowOpacitySlider_OnValueChanged" />
                        <TextBlock
                            x:Name="WindowOpacityValueText"
                            Grid.Column="1"
                            MinWidth="48"
                            VerticalAlignment="Center"
                            Style="{StaticResource LatinDigitsTextBlock}"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource SamtGoldBrush}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Calendar / Hijri / special-day reminders -->
            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE787;" FontSize="16" Foreground="{StaticResource SamtGoldBrush}"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="CalendarSectionHeader" FontWeight="SemiBold" FontSize="16"
                                   Foreground="{StaticResource SamtGoldBrush}" TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="CalendarDisclaimerText" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock x:Name="HijriOffsetLabel" VerticalAlignment="Center" TextWrapping="Wrap" />
                        <NumberBox
                            x:Name="HijriOffsetBox"
                            Language="en-US"
                            FontFamily="{StaticResource SamtNumericFont}"
                            Minimum="-3"
                            Maximum="3"
                            SmallChange="1"
                            LargeChange="1"
                            SpinButtonPlacementMode="Inline"
                            Width="140"
                            ValueChanged="HijriOffsetBox_OnValueChanged" />
                    </StackPanel>
                    <TextBlock x:Name="HijriOffsetHint" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                    <TextBlock x:Name="CalendarCountryLabel" Opacity="0.75" TextWrapping="Wrap" />
                    <ComboBox x:Name="CalendarCountryBox" HorizontalAlignment="Stretch" MinWidth="120"
                              FontFamily="{StaticResource SamtUiFont}"
                              SelectionChanged="CalendarCountryBox_OnSelectionChanged">
                        <ComboBoxItem x:Name="CalendarCountryDefaultItem" Tag="default" />
                        <ComboBoxItem x:Name="CalendarCountryDzItem" Tag="DZ" />
                    </ComboBox>
                    <ToggleSwitch x:Name="SpecialDayMasterToggle" Toggled="SpecialDayMasterToggle_OnToggled" />
                    <ToggleSwitch x:Name="SpecialDayIslamicToggle" Toggled="SpecialDaySetToggle_OnToggled" />
                    <ToggleSwitch x:Name="SpecialDayCountryToggle" Toggled="SpecialDaySetToggle_OnToggled" />
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="SpecialDayTimeLabel" Opacity="0.75" />
                        <TextBox
                            x:Name="SpecialDayTimeBox"
                            Style="{StaticResource LatinDigitsTextBox}"
                            Language="en-US"
                            PlaceholderText="09:00"
                            LostFocus="SpecialDayTimeBox_OnLostFocus"
                            KeyDown="SpecialDayTimeBox_OnKeyDown" />
                    </StackPanel>
                    <TextBlock x:Name="CalendarDeliveryLabel" Opacity="0.75" TextWrapping="Wrap" />
                    <CheckBox x:Name="DeliveryToastCheck" Checked="CalendarDelivery_OnChanged" Unchecked="CalendarDelivery_OnChanged" />
                    <CheckBox x:Name="DeliverySoundCheck" Checked="CalendarDelivery_OnChanged" Unchecked="CalendarDelivery_OnChanged" />
                    <CheckBox x:Name="DeliverySilentWindowCheck" Checked="CalendarDelivery_OnChanged" Unchecked="CalendarDelivery_OnChanged" />
                    <TextBlock x:Name="CalendarDeliveryHint" FontSize="12" Opacity="0.6" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Adhkar reminders: type + default time / post-prayer delay -->
            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8D7;" FontSize="16" Foreground="{StaticResource SamtGoldBrush}"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="AdhkarSectionHeader" FontWeight="SemiBold" FontSize="16"
                                   Foreground="{StaticResource SamtGoldBrush}" TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="AdhkarSectionHint" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    <ToggleSwitch x:Name="AdhkarMasterToggle" Toggled="AdhkarMasterToggle_OnToggled" />
                    <ToggleSwitch x:Name="AdhkarAutoAdvanceToggle" Toggled="AdhkarAutoAdvanceToggle_OnToggled" />

                    <!-- Morning -->
                    <Grid ColumnSpacing="10" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="120" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ToggleSwitch x:Name="AdhkarMorningToggle" Grid.Column="0"
                                      Toggled="AdhkarCollectionToggle_OnToggled" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock x:Name="AdhkarMorningTimeLabel" Opacity="0.75" VerticalAlignment="Center" />
                            <TextBox
                                x:Name="AdhkarMorningTimeBox"
                                Style="{StaticResource LatinDigitsTextBox}"
                                Width="72"
                                PlaceholderText="06:00"
                                LostFocus="AdhkarTimeBox_OnLostFocus"
                                KeyDown="AdhkarTimeBox_OnKeyDown" />
                        </StackPanel>
                    </Grid>

                    <!-- Evening -->
                    <Grid ColumnSpacing="10" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="120" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ToggleSwitch x:Name="AdhkarEveningToggle" Grid.Column="0"
                                      Toggled="AdhkarCollectionToggle_OnToggled" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock x:Name="AdhkarEveningTimeLabel" Opacity="0.75" VerticalAlignment="Center" />
                            <TextBox
                                x:Name="AdhkarEveningTimeBox"
                                Style="{StaticResource LatinDigitsTextBox}"
                                Width="72"
                                PlaceholderText="17:00"
                                LostFocus="AdhkarTimeBox_OnLostFocus"
                                KeyDown="AdhkarTimeBox_OnKeyDown" />
                        </StackPanel>
                    </Grid>

                    <!-- After prayer -->
                    <StackPanel Spacing="6">
                        <ToggleSwitch x:Name="AdhkarAfterToggle" Toggled="AdhkarCollectionToggle_OnToggled" />
                        <TextBlock x:Name="AdhkarAfterPrayerHint" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="AdhkarAfterDelayLabel" Opacity="0.75" VerticalAlignment="Center" />
                            <TextBox
                                x:Name="AdhkarAfterDelayBox"
                                Style="{StaticResource LatinDigitsTextBox}"
                                Width="72"
                                PlaceholderText="0"
                                LostFocus="AdhkarTimeBox_OnLostFocus"
                                KeyDown="AdhkarTimeBox_OnKeyDown" />
                            <TextBlock x:Name="AdhkarAfterDelayUnit" Opacity="0.6" VerticalAlignment="Center"
                                       Language="en-US" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Sleep -->
                    <Grid ColumnSpacing="10" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="120" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ToggleSwitch x:Name="AdhkarSleepToggle" Grid.Column="0"
                                      Toggled="AdhkarCollectionToggle_OnToggled" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock x:Name="AdhkarSleepTimeLabel" Opacity="0.75" VerticalAlignment="Center" />
                            <TextBox
                                x:Name="AdhkarSleepTimeBox"
                                Style="{StaticResource LatinDigitsTextBox}"
                                Width="72"
                                PlaceholderText="22:00"
                                LostFocus="AdhkarTimeBox_OnLostFocus"
                                KeyDown="AdhkarTimeBox_OnKeyDown" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- About / community -->
            <Border Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE946;" FontSize="16" Foreground="{StaticResource SamtGoldBrush}"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="AboutSectionHeader" FontWeight="SemiBold" FontSize="16"
                                   Foreground="{StaticResource SamtGoldBrush}" TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Image x:Name="PublisherLogo" Width="72" Height="72" Stretch="Uniform"
                               VerticalAlignment="Center" />
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock FontFamily="{StaticResource SamtDisplayFont}" FontSize="22"
                                       Foreground="{StaticResource SamtGoldBrush}" Text="سَمت / SAMT" />
                            <TextBlock x:Name="PublisherText" Opacity="0.8" FontSize="13" TextWrapping="Wrap" />
                            <TextBlock x:Name="VersionText" Style="{StaticResource LatinDigitsTextBlock}"
                                       Opacity="0.7" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="CommunitySectionHeader" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap" />
                    <Button x:Name="GitHubButton" HorizontalAlignment="Stretch" Click="GitHubButton_OnClick">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                            <TextBlock x:Name="GitHubButtonLabel" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
