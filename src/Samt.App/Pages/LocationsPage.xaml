<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.LocationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <Grid ColumnSpacing="20" MaxWidth="960">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="12">
                <TextBlock x:Name="ListHeader" FontSize="20" FontWeight="SemiBold" />
                <ListView
                    x:Name="LocationList"
                    ItemsSource="{x:Bind ViewModel.Locations, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedLocation, Mode=TwoWay}"
                    DisplayMemberPath="DisplayName"
                    Height="320" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="ActivateButton" Click="ActivateButton_OnClick" />
                    <Button x:Name="NewButton" Click="NewButton_OnClick" />
                    <Button x:Name="DeleteButton" Click="DeleteButton_OnClick" />
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1" Padding="16" CornerRadius="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="EditorHeader" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Name="NameLabel" Opacity="0.75" />
                    <TextBox Text="{x:Bind ViewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock x:Name="LatLabel" Opacity="0.75" />
                    <TextBox Text="{x:Bind ViewModel.Latitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" />
                    <TextBlock x:Name="LonLabel" Opacity="0.75" />
                    <TextBox Text="{x:Bind ViewModel.Longitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" />
                    <TextBlock x:Name="TzLabel" Opacity="0.75" />
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{x:Bind ViewModel.TimeZoneIds}"
                              SelectedItem="{x:Bind ViewModel.TimeZoneId, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="SaveButton" Click="SaveButton_OnClick" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="GpsButton" Click="GpsButton_OnClick" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.85" />
                    <TextBlock x:Name="PrivacyNote" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
