<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Samt_App.Pages.LocationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    FontFamily="{StaticResource SamtUiFont}">

    <ScrollViewer Padding="28,24">
        <Grid ColumnSpacing="20" MaxWidth="960">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="12">
                <TextBlock x:Name="ListHeader" Style="{StaticResource SamtPageTitle}" FontSize="26" />
                <ListView
                    x:Name="LocationList"
                    FontFamily="{StaticResource SamtUiFont}"
                    ItemsSource="{x:Bind ViewModel.Locations, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedLocation, Mode=TwoWay}"
                    DisplayMemberPath="DisplayName"
                    Height="320" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="ActivateButton" Click="ActivateButton_OnClick" />
                    <Button x:Name="NewButton" Click="NewButton_OnClick" />
                    <Button x:Name="DeleteButton" Click="DeleteButton_OnClick" />
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1" Padding="18" CornerRadius="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="EditorHeader" Style="{StaticResource SamtPageTitle}" FontSize="22" />

                    <TextBlock x:Name="PlaceSearchLabel" Opacity="0.75" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="PlaceSearchBox"
                            Text="{x:Bind ViewModel.PlaceQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Kennadsa, Oran…" />
                        <Button
                            x:Name="PlaceSearchButton"
                            Grid.Column="1"
                            VerticalAlignment="Stretch"
                            Click="PlaceSearchButton_OnClick" />
                    </Grid>
                    <ListView
                        x:Name="PlaceResultsList"
                        Height="100"
                        ItemsSource="{x:Bind ViewModel.PlaceResults, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedPlaceResult, Mode=TwoWay}"
                        DoubleTapped="PlaceResultsList_OnDoubleTapped"
                        SelectionChanged="PlaceResultsList_OnSelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="2" Padding="4,6">
                                    <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" />
                                    <TextBlock
                                        Style="{StaticResource LatinDigitsTextBlock}"
                                        Text="{Binding CoordinateText}"
                                        Opacity="0.65"
                                        FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="PlaceSearchAttribution" FontSize="11" Opacity="0.55" TextWrapping="Wrap" />

                    <TextBlock x:Name="NameLabel" Opacity="0.75" />
                    <TextBox Text="{x:Bind ViewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock x:Name="LatLabel" Opacity="0.75" />
                    <TextBox
                        Style="{StaticResource LatinDigitsTextBox}"
                        Text="{x:Bind ViewModel.Latitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="31.5569" />
                    <TextBlock x:Name="LonLabel" Opacity="0.75" />
                    <TextBox
                        Style="{StaticResource LatinDigitsTextBox}"
                        Text="{x:Bind ViewModel.Longitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="-2.4181" />
                    <TextBlock x:Name="TzLabel" Opacity="0.75" />
                    <ComboBox
                        Language="en-US"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.TimeZoneIds}"
                        SelectedItem="{x:Bind ViewModel.TimeZoneId, Mode=TwoWay}" />
                    <TextBlock x:Name="FridaySectionLabel" Style="{StaticResource SamtSectionLabel}" Margin="0,8,0,0" />
                    <TextBlock x:Name="FridayModeLabel" Opacity="0.75" />
                    <ComboBox
                        x:Name="FridayModeBox"
                        HorizontalAlignment="Stretch"
                        SelectedIndex="{x:Bind ViewModel.FridayModeIndex, Mode=TwoWay}">
                        <ComboBoxItem x:Name="FridayFollowDhuhrItem" />
                        <ComboBoxItem x:Name="FridayFixedTimeItem" />
                    </ComboBox>
                    <TextBlock x:Name="FixedFridayLabel" Opacity="0.75" />
                    <TextBox
                        Style="{StaticResource LatinDigitsTextBox}"
                        Text="{x:Bind ViewModel.FixedFridayTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="13:30"
                        IsEnabled="{x:Bind ViewModel.IsFixedFridayTime, Mode=OneWay}" />
                    <CheckBox
                        x:Name="SuppressDhuhrCheck"
                        IsChecked="{x:Bind ViewModel.SuppressDhuhrOnFriday, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="SaveButton" Click="SaveButton_OnClick" Style="{StaticResource AccentButtonStyle}" />
                        <Button x:Name="GpsButton" Click="GpsButton_OnClick" />
                    </StackPanel>
                    <TextBlock
                        Language="en-US"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Opacity="0.85" />
                    <TextBlock x:Name="PrivacyNote" FontSize="12" Opacity="0.65" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
