<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Samt_App.Overlay.SetupWizardWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="SAMT Setup">

    <Grid Background="{StaticResource SamtShellGradient}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid
            x:Name="TitleBarRoot"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{StaticResource SamtHairlineBrush}"
            BorderThickness="0,0,0,1">
            <Border x:Name="TitleBarDrag" Background="Transparent">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="14,0,8,0">
                    <FontIcon Glyph="&#xE774;" FontSize="14" Foreground="{StaticResource SamtGoldBrush}" />
                    <TextBlock
                        x:Name="TitleText"
                        FontFamily="{StaticResource SamtDisplayFont}"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource SamtGoldBrush}"
                        VerticalAlignment="Center" />
                </StackPanel>
            </Border>
            <Button
                x:Name="CloseCaptionButton"
                HorizontalAlignment="Right"
                Click="CloseCaptionButton_OnClick">
                <FontIcon Glyph="&#xE8BB;" FontSize="12" />
            </Button>
        </Grid>

        <ScrollViewer
            Grid.Row="1"
            Padding="24,16"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollMode="Disabled">
            <StackPanel MaxWidth="560" HorizontalAlignment="Stretch" Spacing="14">
                <TextBlock
                    x:Name="WelcomeText"
                    FontFamily="{StaticResource SamtDisplayFont}"
                    FontSize="26"
                    Foreground="{StaticResource SamtGoldBrush}"
                    TextWrapping="Wrap" />

                <!-- Step progress dots -->
                <StackPanel x:Name="StepDots" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" />

                <TextBlock
                    x:Name="StepTitle"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource SamtIvoryBrush}"
                    TextWrapping="Wrap" />
                <TextBlock
                    x:Name="StepHint"
                    FontSize="13"
                    Opacity="0.75"
                    Foreground="{StaticResource SamtIvoryMutedBrush}"
                    TextWrapping="Wrap" />

                <!-- Step 1: Location -->
                <StackPanel x:Name="Step1Panel" Spacing="10">
                    <Button x:Name="GpsButton" HorizontalAlignment="Stretch" Click="GpsButton_OnClick">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE707;" FontSize="14" />
                            <TextBlock x:Name="GpsButtonLabel" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="PlaceSearchBox"
                            Grid.Column="0"
                            FontFamily="{StaticResource SamtUiFont}" />
                        <Button
                            x:Name="PlaceSearchButton"
                            Grid.Column="1"
                            Click="PlaceSearchButton_OnClick" />
                    </Grid>
                    <ListView
                        x:Name="PlaceResultsList"
                        MaxHeight="140"
                        SelectionMode="Single"
                        SelectionChanged="PlaceResultsList_OnSelectionChanged" />
                    <TextBlock x:Name="PlaceSearchAttribution" FontSize="11" Opacity="0.55" TextWrapping="Wrap" />
                    <ComboBox
                        x:Name="SeedCityBox"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="SeedCityBox_OnSelectionChanged" />
                    <TextBlock x:Name="LocationStatusLabel" Opacity="0.75" TextWrapping="Wrap" />
                    <TextBlock
                        x:Name="LocationStatusValue"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource SamtGoldBrush}"
                        TextWrapping="Wrap"
                        Style="{StaticResource LatinDigitsTextBlock}" />
                    <TextBlock x:Name="LocationBusyText" Opacity="0.65" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Step 2: Prayer times -->
                <StackPanel x:Name="Step2Panel" Spacing="10" Visibility="Collapsed">
                    <TextBlock x:Name="CalcMethodLabel" Opacity="0.75" />
                    <ComboBox x:Name="MethodBox" HorizontalAlignment="Stretch" SelectionChanged="MethodBox_OnSelectionChanged" />
                    <TextBlock x:Name="MadhabLabel" Opacity="0.75" />
                    <ComboBox x:Name="MadhabBox" HorizontalAlignment="Stretch" SelectionChanged="MadhabBox_OnSelectionChanged">
                        <ComboBoxItem x:Name="MadhabStandardItem" Tag="Standard" />
                        <ComboBoxItem x:Name="MadhabHanafiItem" Tag="Hanafi" />
                    </ComboBox>
                    <Border
                        Padding="12"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{StaticResource SamtHairlineBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <TextBlock
                            x:Name="PrayerTimesPreview"
                            Style="{StaticResource LatinDigitsTextBlock}"
                            TextWrapping="Wrap"
                            LineHeight="22" />
                    </Border>
                </StackPanel>

                <!-- Step 3: Adhkar schedule -->
                <StackPanel x:Name="Step3Panel" Spacing="10" Visibility="Collapsed">
                    <ToggleSwitch x:Name="AdhkarMasterToggle" />
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ToggleSwitch x:Name="MorningToggle" Grid.Column="0" />
                        <TextBox
                            x:Name="MorningTimeBox"
                            Grid.Column="1"
                            Width="72"
                            Style="{StaticResource LatinDigitsTextBox}"
                            PlaceholderText="06:00" />
                    </Grid>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ToggleSwitch x:Name="EveningToggle" Grid.Column="0" />
                        <TextBox
                            x:Name="EveningTimeBox"
                            Grid.Column="1"
                            Width="72"
                            Style="{StaticResource LatinDigitsTextBox}"
                            PlaceholderText="17:00" />
                    </Grid>
                    <ToggleSwitch x:Name="AfterToggle" />
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ToggleSwitch x:Name="SleepToggle" Grid.Column="0" />
                        <TextBox
                            x:Name="SleepTimeBox"
                            Grid.Column="1"
                            Width="72"
                            Style="{StaticResource LatinDigitsTextBox}"
                            PlaceholderText="22:00" />
                    </Grid>
                </StackPanel>

                <!-- Step 4: Tour -->
                <StackPanel x:Name="Step4Panel" Spacing="10" Visibility="Collapsed">
                    <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE138;" FontSize="18" Foreground="{StaticResource SamtGoldBrush}" />
                            <TextBlock x:Name="TourTray" TextWrapping="Wrap" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE80F;" FontSize="18" Foreground="{StaticResource SamtGoldBrush}" />
                            <TextBlock x:Name="TourToday" TextWrapping="Wrap" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xEA8F;" FontSize="18" Foreground="{StaticResource SamtGoldBrush}" />
                            <TextBlock x:Name="TourAlerts" TextWrapping="Wrap" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{StaticResource SamtHairlineBrush}" BorderThickness="1" CornerRadius="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE8D7;" FontSize="18" Foreground="{StaticResource SamtGoldBrush}" />
                            <TextBlock x:Name="TourAdhkar" TextWrapping="Wrap" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer actions -->
        <Grid
            Grid.Row="2"
            Padding="20,12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{StaticResource SamtHairlineBrush}"
            BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="SkipButton" Grid.Column="0" Click="SkipButton_OnClick" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:Name="BackButton" Click="BackButton_OnClick" />
                <Button
                    x:Name="NextButton"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="NextButton_OnClick" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
